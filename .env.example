# K12 成绩追踪系统 - 部署配置
# 复制为 .env 并修改

# 后端监听端口
BACKEND_PORT=8000

# 前端监听端口
FRONTEND_PORT=80

# 数据库文件存储路径（容器内）
DATABASE_URL=sqlite:///./data/k12.db

# JWT 密钥（务必修改为随机字符串！）
SECRET_KEY=k12-grade-system-secret-key-change-in-production

# JWT 算法
ALGORITHM=HS256

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440
